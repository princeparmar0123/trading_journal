# Cloudinary (client uploads — works on GitHub Pages and local dev)
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name

# Option A (recommended for GitHub Pages): unsigned upload preset from Cloudinary dashboard
VITE_CLOUDINARY_UPLOAD_PRESET=your_unsigned_preset

# Option B: signed uploads from the browser (API secret is embedded in the build — use with care)
# VITE_CLOUDINARY_API_KEY=
# VITE_CLOUDINARY_API_SECRET=

# Server-only (optional, for Cloudflare / TanStack server functions)
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
